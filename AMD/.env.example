# Copy to .env and fill in values — never commit .env to git

# Dev proxy: point the Vite dev server at the cloud API
VITE_API_PROXY=http://<your-cloud-ip>

# Optional: set the API base URL for the built console
VITE_API_BASE=

# vLLM endpoint (used by the API service)
VLLM_BASE_URL=http://127.0.0.1:9001

# Optional: vLLM bearer token (leave blank for local/no-auth)
VLLM_API_KEY=

# CORS origins allowed by the FastAPI backend (comma-separated)
VESPER_CORS_ORIGINS=
