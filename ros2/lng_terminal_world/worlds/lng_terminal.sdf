<?xml version="1.0" ?>
<sdf version="1.9">
  <world name="lng_terminal">

    <physics type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="gz-sim-physics-system"        name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-user-commands-system"  name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-sensors-system"        name="gz::sim::systems::Sensors"/>
    <plugin filename="gz-sim-particle-emitter-system" name="gz::sim::systems::ParticleEmitter"/>

    <!-- ── Cinematic lighting & sky ── -->
    <scene>
      <ambient>0.25 0.22 0.18 1.0</ambient>
      <background>0.53 0.65 0.75 1.0</background>
      <shadows>true</shadows>
      <fog>
        <color>0.85 0.80 0.72 1</color>
        <type>linear</type>
        <start>40</start>
        <end>120</end>
        <density>0.006</density>
      </fog>
      <sky>
        <time>7.5</time>
        <sunrise>6</sunrise>
        <sunset>20</sunset>
      </sky>
    </scene>

    <!-- Golden-hour directional sun — low angle creates long dramatic shadows -->
    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 50 0 0.4 -0.8</pose>
      <diffuse>1.0 0.92 0.78 1</diffuse>
      <specular>0.5 0.46 0.38 1</specular>
      <direction>-0.5 -0.3 -0.7</direction>
      <attenuation><range>1000</range><constant>0.9</constant><linear>0.01</linear><quadratic>0.001</quadratic></attenuation>
    </light>

    <!-- Soft ambient fill from sky (north) -->
    <light type="directional" name="sky_fill">
      <cast_shadows>false</cast_shadows>
      <pose>0 0 20 0 0 0</pose>
      <diffuse>0.35 0.42 0.55 1</diffuse>
      <specular>0.05 0.05 0.08 1</specular>
      <direction>0.2 0.1 -1</direction>
    </light>

    <!-- Emergency red strobe near tank_b (incident atmosphere) -->
    <light type="point" name="emergency_strobe">
      <cast_shadows>false</cast_shadows>
      <pose>-8 8 3 0 0 0</pose>
      <diffuse>1.0 0.08 0.05 1</diffuse>
      <specular>0.4 0.02 0.01 1</specular>
      <attenuation><range>18</range><constant>0.3</constant><linear>0.1</linear><quadratic>0.05</quadratic></attenuation>
    </light>

    <!-- ── Ground: industrial concrete apron ── -->
    <model name="ground_concrete">
      <static>true</static>
      <pose>0 0 0 0 0 0</pose>
      <link name="surface">
        <collision name="col">
          <geometry><plane><normal>0 0 1</normal><size>120 120</size></plane></geometry>
        </collision>
        <visual name="vis">
          <geometry><plane><normal>0 0 1</normal><size>120 120</size></plane></geometry>
          <material>
            <ambient>0.38 0.36 0.33 1</ambient>
            <diffuse>0.52 0.50 0.46 1</diffuse>
            <specular>0.06 0.06 0.06 1</specular>
            <pbr>
              <metal>
                <roughness>0.92</roughness>
                <metalness>0.0</metalness>
              </metal>
            </pbr>
          </material>
        </visual>
      </link>
    </model>

    <!-- ── Perimeter walls — weathered concrete ── -->
    <model name="perimeter_north">
      <static>true</static>
      <pose>0 30 1.5 0 0 0</pose>
      <link name="wall">
        <collision name="col"><geometry><box><size>62 0.4 3</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>62 0.4 3</size></box></geometry>
          <material>
            <ambient>0.42 0.40 0.37 1</ambient>
            <diffuse>0.55 0.53 0.49 1</diffuse>
            <specular>0.04 0.04 0.04 1</specular>
            <pbr><metal><roughness>0.95</roughness><metalness>0.0</metalness></metal></pbr>
          </material>
        </visual>
      </link>
    </model>

    <model name="perimeter_south">
      <static>true</static>
      <pose>0 -30 1.5 0 0 0</pose>
      <link name="wall">
        <collision name="col"><geometry><box><size>62 0.4 3</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>62 0.4 3</size></box></geometry>
          <material>
            <ambient>0.42 0.40 0.37 1</ambient>
            <diffuse>0.55 0.53 0.49 1</diffuse>
            <specular>0.04 0.04 0.04 1</specular>
            <pbr><metal><roughness>0.95</roughness><metalness>0.0</metalness></metal></pbr>
          </material>
        </visual>
      </link>
    </model>

    <model name="perimeter_east">
      <static>true</static>
      <pose>31 0 1.5 0 0 1.5707</pose>
      <link name="wall">
        <collision name="col"><geometry><box><size>62 0.4 3</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>62 0.4 3</size></box></geometry>
          <material>
            <ambient>0.42 0.40 0.37 1</ambient>
            <diffuse>0.55 0.53 0.49 1</diffuse>
            <specular>0.04 0.04 0.04 1</specular>
            <pbr><metal><roughness>0.95</roughness><metalness>0.0</metalness></metal></pbr>
          </material>
        </visual>
      </link>
    </model>

    <model name="perimeter_west">
      <static>true</static>
      <pose>-31 0 1.5 0 0 1.5707</pose>
      <link name="wall">
        <collision name="col"><geometry><box><size>62 0.4 3</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>62 0.4 3</size></box></geometry>
          <material>
            <ambient>0.42 0.40 0.37 1</ambient>
            <diffuse>0.55 0.53 0.49 1</diffuse>
            <specular>0.04 0.04 0.04 1</specular>
            <pbr><metal><roughness>0.95</roughness><metalness>0.0</metalness></metal></pbr>
          </material>
        </visual>
      </link>
    </model>

    <!-- ── LNG Tank A — brushed steel cylinder with domed cap ── -->
    <model name="tank_a">
      <static>true</static>
      <pose>10 8 0 0 0 0</pose>
      <link name="body">
        <collision name="col"><geometry><cylinder><radius>4</radius><length>8</length></cylinder></geometry></collision>
        <visual name="shell">
          <pose>0 0 4 0 0 0</pose>
          <geometry><cylinder><radius>4</radius><length>8</length></cylinder></geometry>
          <material>
            <ambient>0.72 0.74 0.78 1</ambient>
            <diffuse>0.80 0.82 0.86 1</diffuse>
            <specular>0.60 0.62 0.65 1</specular>
            <pbr>
              <metal>
                <roughness>0.28</roughness>
                <metalness>0.85</metalness>
              </metal>
            </pbr>
          </material>
        </visual>
        <visual name="dome_top">
          <pose>0 0 8.1 0 0 0</pose>
          <geometry><sphere><radius>4.05</radius></sphere></geometry>
          <material>
            <ambient>0.68 0.70 0.74 1</ambient>
            <diffuse>0.76 0.78 0.82 1</diffuse>
            <specular>0.65 0.66 0.68 1</specular>
            <pbr><metal><roughness>0.22</roughness><metalness>0.88</metalness></metal></pbr>
          </material>
        </visual>
        <visual name="base_ring">
          <pose>0 0 0.15 0 0 0</pose>
          <geometry><cylinder><radius>4.3</radius><length>0.3</length></cylinder></geometry>
          <material>
            <ambient>0.30 0.30 0.32 1</ambient>
            <diffuse>0.38 0.38 0.40 1</diffuse>
            <specular>0.2 0.2 0.2 1</specular>
            <pbr><metal><roughness>0.55</roughness><metalness>0.7</metalness></metal></pbr>
          </material>
        </visual>
      </link>
    </model>

    <!-- ── LNG Tank B — leak source, slightly corroded/rust-stained ── -->
    <model name="tank_b">
      <static>true</static>
      <pose>-8 10 0 0 0 0</pose>
      <link name="body">
        <collision name="col"><geometry><cylinder><radius>4</radius><length>8</length></cylinder></geometry></collision>
        <visual name="shell">
          <pose>0 0 4 0 0 0</pose>
          <geometry><cylinder><radius>4</radius><length>8</length></cylinder></geometry>
          <material>
            <ambient>0.65 0.60 0.55 1</ambient>
            <diffuse>0.70 0.65 0.58 1</diffuse>
            <specular>0.35 0.32 0.28 1</specular>
            <pbr>
              <metal>
                <roughness>0.58</roughness>
                <metalness>0.62</metalness>
              </metal>
            </pbr>
          </material>
        </visual>
        <visual name="dome_top">
          <pose>0 0 8.1 0 0 0</pose>
          <geometry><sphere><radius>4.05</radius></sphere></geometry>
          <material>
            <ambient>0.60 0.55 0.50 1</ambient>
            <diffuse>0.66 0.60 0.53 1</diffuse>
            <specular>0.30 0.28 0.24 1</specular>
            <pbr><metal><roughness>0.62</roughness><metalness>0.58</metalness></metal></pbr>
          </material>
        </visual>
        <visual name="base_ring">
          <pose>0 0 0.15 0 0 0</pose>
          <geometry><cylinder><radius>4.3</radius><length>0.3</length></cylinder></geometry>
          <material>
            <ambient>0.28 0.24 0.20 1</ambient>
            <diffuse>0.35 0.30 0.25 1</diffuse>
            <specular>0.1 0.08 0.06 1</specular>
            <pbr><metal><roughness>0.80</roughness><metalness>0.55</metalness></metal></pbr>
          </material>
        </visual>
        <!-- Rust streak down the side -->
        <visual name="rust_streak">
          <pose>3.9 0 3 0 0 0</pose>
          <geometry><box><size>0.05 0.8 5</size></box></geometry>
          <material>
            <ambient>0.55 0.28 0.10 1</ambient>
            <diffuse>0.62 0.32 0.12 1</diffuse>
            <specular>0.02 0.01 0.0 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- ── Gas leak plume (particle emitter) near tank_b base ── -->
    <model name="gas_plume">
      <static>true</static>
      <pose>-5 9 0.3 0 0 0</pose>
      <link name="emitter_link">
        <particle_emitter name="leak_plume" type="box">
          <emitting>true</emitting>
          <size>0.4 0.4 0.4</size>
          <particle_size>0.6 0.6 0.6</particle_size>
          <rate>8</rate>
          <min_velocity>0.3</min_velocity>
          <max_velocity>0.9</max_velocity>
          <lifetime>4</lifetime>
          <color_start>0.75 0.82 0.75 0.55</color_start>
          <color_end>0.85 0.90 0.85 0.0</color_end>
          <scale_rate>0.6</scale_rate>
        </particle_emitter>
      </link>
    </model>

    <!-- ── Gate structure — steel I-beam frame ── -->
    <model name="gate_left_post">
      <static>true</static>
      <pose>25 -4 3 0 0 0</pose>
      <link name="post">
        <visual name="vis">
          <geometry><box><size>0.25 0.25 6</size></box></geometry>
          <material>
            <ambient>0.28 0.28 0.30 1</ambient>
            <diffuse>0.35 0.35 0.38 1</diffuse>
            <specular>0.3 0.3 0.32 1</specular>
            <pbr><metal><roughness>0.45</roughness><metalness>0.78</metalness></metal></pbr>
          </material>
        </visual>
        <collision name="col"><geometry><box><size>0.25 0.25 6</size></box></geometry></collision>
      </link>
    </model>

    <model name="gate_right_post">
      <static>true</static>
      <pose>25 4 3 0 0 0</pose>
      <link name="post">
        <visual name="vis">
          <geometry><box><size>0.25 0.25 6</size></box></geometry>
          <material>
            <ambient>0.28 0.28 0.30 1</ambient>
            <diffuse>0.35 0.35 0.38 1</diffuse>
            <specular>0.3 0.3 0.32 1</specular>
            <pbr><metal><roughness>0.45</roughness><metalness>0.78</metalness></metal></pbr>
          </material>
        </visual>
        <collision name="col"><geometry><box><size>0.25 0.25 6</size></box></geometry></collision>
      </link>
    </model>

    <model name="gate_beam">
      <static>true</static>
      <pose>25 0 6.15 0 0 0</pose>
      <link name="beam">
        <visual name="vis">
          <geometry><box><size>0.2 8.5 0.25</size></box></geometry>
          <material>
            <ambient>0.28 0.28 0.30 1</ambient>
            <diffuse>0.35 0.35 0.38 1</diffuse>
            <specular>0.3 0.3 0.32 1</specular>
            <pbr><metal><roughness>0.45</roughness><metalness>0.78</metalness></metal></pbr>
          </material>
        </visual>
      </link>
    </model>

    <!-- Warning sign on gate beam -->
    <model name="hazard_sign">
      <static>true</static>
      <pose>25 0 5 0 0 1.5707</pose>
      <link name="sign">
        <visual name="vis">
          <geometry><box><size>0.02 0.6 0.6</size></box></geometry>
          <material>
            <ambient>0.95 0.82 0.0 1</ambient>
            <diffuse>1.0 0.88 0.0 1</diffuse>
            <specular>0.1 0.09 0.0 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- ── CCTV pole + camera housing ── -->
    <model name="cctv_pole">
      <static>true</static>
      <pose>22 0 0 0 0 0</pose>
      <link name="pole">
        <visual name="vis">
          <pose>0 0 2.5 0 0 0</pose>
          <geometry><cylinder><radius>0.05</radius><length>5</length></cylinder></geometry>
          <material>
            <ambient>0.25 0.25 0.27 1</ambient>
            <diffuse>0.32 0.32 0.34 1</diffuse>
            <specular>0.35 0.35 0.36 1</specular>
            <pbr><metal><roughness>0.35</roughness><metalness>0.82</metalness></metal></pbr>
          </material>
        </visual>
        <collision name="col"><pose>0 0 2.5 0 0 0</pose><geometry><cylinder><radius>0.05</radius><length>5</length></cylinder></geometry></collision>
      </link>
    </model>

    <model name="cctv_gate">
      <static>true</static>
      <pose>22 0 5.2 0 0.45 3.14</pose>
      <link name="body">
        <visual name="housing">
          <geometry><box><size>0.12 0.30 0.12</size></box></geometry>
          <material>
            <ambient>0.08 0.08 0.08 1</ambient>
            <diffuse>0.12 0.12 0.12 1</diffuse>
            <specular>0.25 0.25 0.25 1</specular>
            <pbr><metal><roughness>0.30</roughness><metalness>0.75</metalness></metal></pbr>
          </material>
        </visual>
        <visual name="lens">
          <pose>0.07 0 0 0 1.5707 0</pose>
          <geometry><cylinder><radius>0.035</radius><length>0.04</length></cylinder></geometry>
          <material>
            <ambient>0.02 0.02 0.08 1</ambient>
            <diffuse>0.03 0.03 0.12 1</diffuse>
            <specular>0.6 0.6 0.9 1</specular>
            <pbr><metal><roughness>0.05</roughness><metalness>0.0</metalness></metal></pbr>
          </material>
        </visual>
        <sensor name="cctv_cam" type="camera">
          <update_rate>2</update_rate>
          <camera>
            <horizontal_fov>1.3962634</horizontal_fov>
            <image><width>1280</width><height>720</height><format>R8G8B8</format></image>
            <clip><near>0.1</near><far>120</far></clip>
            <noise><type>gaussian</type><mean>0</mean><stddev>0.003</stddev></noise>
          </camera>
        </sensor>
      </link>
    </model>

    <!-- ── Gas sensor unit — orange enclosure on post ── -->
    <model name="gas_sensor_post">
      <static>true</static>
      <pose>-8 6 0 0 0 0</pose>
      <link name="post">
        <visual name="vis">
          <pose>0 0 0.6 0 0 0</pose>
