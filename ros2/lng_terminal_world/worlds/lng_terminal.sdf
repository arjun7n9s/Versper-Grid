    <!-- ═══ B-4 GAS PLUME: opaque core, semi-transparent foggy outer (no z-fighting) ═══ -->
    <!-- Core column: smaller than tank radius (8m), opaque inner → translucent outer -->
    <model name="plume_lvl1"><static>true</static><pose>68 -64 2.5 0 0 0</pose><link name="l"><visual name="v">
      <geometry><sphere><radius>1.4</radius></sphere></geometry>
