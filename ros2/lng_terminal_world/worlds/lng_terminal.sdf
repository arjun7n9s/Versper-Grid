<?xml version="1.0" ?>
<!--
  NORTHGATE LNG TERMINAL COMPLEX — VesperGrid Operational Twin
  ═══════════════════════════════════════════════════════════════
  Massive 1.2×1.2 km petrochemical facility on coastal plain.
  Surrounded by coastal mountain range (impassable).

  SECTOR 1 (primary, active cameras): Storage Farm — current incident
  SECTOR 2 (east, across inter-sector gate): Processing Complex
  SECTOR 3 (north, across inter-sector gate): Refinery Tower
  SECTOR 4 (far SE): Cryogenic Export Terminal

  INCIDENT t+00:00 = 03:42:17 UTC
  Tank B-4 flange breach. GS-04 trips LEL alarm. Drone D-1 orbits.
  Workers muster SW. CCTV-Gate + CCTV-South stream to VesperGrid API.
  ═══════════════════════════════════════════════════════════════
-->
<sdf version="1.9">
  <world name="lng_terminal">

    <physics type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="gz-sim-physics-system"          name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-user-commands-system"    name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-sensors-system"          name="gz::sim::systems::Sensors"/>

    <!-- Pre-dawn scene: warmer tones, fog visible, grid disabled -->
    <scene>
      <ambient>0.26 0.24 0.22 1.0</ambient>
      <background>0.22 0.26 0.36 1.0</background>
      <shadows>true</shadows>
      <grid>false</grid>
      <origin_visual>false</origin_visual>
      <sky></sky>
      <fog>
        <color>0.28 0.30 0.36 1</color>
        <type>linear</type>
        <start>200</start>
        <end>900</end>
        <density>0.0015</density>
      </fog>
    </scene>

    <!-- Moonlight key light -->
    <light type="directional" name="moonlight">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 200 0 0 0</pose>
      <diffuse>0.32 0.34 0.42 1</diffuse>
      <specular>0.10 0.11 0.16 1</specular>
      <direction>0.3 -0.5 -0.8</direction>
      <attenuation><range>3000</range><constant>0.9</constant><linear>0.0</linear><quadratic>0.0</quadratic></attenuation>
    </light>
    <!-- Dawn hint from NE -->
    <light type="directional" name="dawn_hint">
      <cast_shadows>false</cast_shadows>
      <pose>0 0 100 0 0 0</pose>
      <diffuse>0.20 0.14 0.10 1</diffuse>
      <specular>0.05 0.03 0.02 1</specular>
      <direction>-0.6 -0.4 -0.5</direction>
    </light>

    <!-- Sodium vapour floods around Sector 1 -->
    <light type="point" name="fl_n"><cast_shadows>false</cast_shadows><pose>0 150 28 0 0 0</pose>
      <diffuse>0.90 0.70 0.35 1</diffuse><specular>0.18 0.12 0.04 1</specular>
      <attenuation><range>220</range><constant>0.3</constant><linear>0.015</linear><quadratic>0.0001</quadratic></attenuation></light>
    <light type="point" name="fl_s"><cast_shadows>false</cast_shadows><pose>0 -150 28 0 0 0</pose>
      <diffuse>0.90 0.70 0.35 1</diffuse><specular>0.18 0.12 0.04 1</specular>
      <attenuation><range>220</range><constant>0.3</constant><linear>0.015</linear><quadratic>0.0001</quadratic></attenuation></light>
    <light type="point" name="fl_e"><cast_shadows>false</cast_shadows><pose>150 0 28 0 0 0</pose>
      <diffuse>0.90 0.70 0.35 1</diffuse><specular>0.18 0.12 0.04 1</specular>
      <attenuation><range>220</range><constant>0.3</constant><linear>0.015</linear><quadratic>0.0001</quadratic></attenuation></light>
    <light type="point" name="fl_w"><cast_shadows>false</cast_shadows><pose>-150 0 28 0 0 0</pose>
      <diffuse>0.90 0.70 0.35 1</diffuse><specular>0.18 0.12 0.04 1</specular>
      <attenuation><range>220</range><constant>0.3</constant><linear>0.015</linear><quadratic>0.0001</quadratic></attenuation></light>

    <!-- Distant sector lights to give scale -->
    <light type="point" name="sector2_glow"><cast_shadows>false</cast_shadows><pose>450 0 40 0 0 0</pose>
      <diffuse>0.80 0.55 0.20 1</diffuse><specular>0.1 0.08 0.02 1</specular>
      <attenuation><range>400</range><constant>0.3</constant><linear>0.008</linear><quadratic>0.00003</quadratic></attenuation></light>
    <light type="point" name="sector3_glow"><cast_shadows>false</cast_shadows><pose>0 450 60 0 0 0</pose>
      <diffuse>0.78 0.52 0.18 1</diffuse><specular>0.08 0.06 0.02 1</specular>
      <attenuation><range>400</range><constant>0.3</constant><linear>0.008</linear><quadratic>0.00003</quadratic></attenuation></light>

    <!-- Incident emergency strobes at Tank B-4 -->
    <light type="point" name="emrg1"><cast_shadows>false</cast_shadows><pose>60 -58 5 0 0 0</pose>
      <diffuse>1.0 0.05 0.03 1</diffuse><specular>0.4 0.01 0.01 1</specular>
      <attenuation><range>40</range><constant>0.2</constant><linear>0.07</linear><quadratic>0.03</quadratic></attenuation></light>
    <light type="point" name="emrg2"><cast_shadows>false</cast_shadows><pose>40 -65 5 0 0 0</pose>
      <diffuse>1.0 0.05 0.03 1</diffuse><specular>0.3 0.01 0.01 1</specular>
      <attenuation><range>35</range><constant>0.2</constant><linear>0.07</linear><quadratic>0.03</quadratic></attenuation></light>

    <light type="point" name="flare_glow"><cast_shadows>false</cast_shadows><pose>110 90 60 0 0 0</pose>
      <diffuse>1.0 0.42 0.06 1</diffuse><specular>0.5 0.18 0.01 1</specular>
      <attenuation><range>160</range><constant>0.25</constant><linear>0.02</linear><quadratic>0.0005</quadratic></attenuation></light>

    <!-- Ground — 2 km square dark tarmac -->
    <model name="ground"><static>true</static><pose>0 0 -0.05 0 0 0</pose><link name="l">
      <collision name="c"><geometry><box><size>2000 2000 0.1</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>2000 2000 0.1</size></box></geometry>
        <material><ambient>0.18 0.18 0.18 1</ambient><diffuse>0.24 0.24 0.24 1</diffuse><specular>0.03 0.03 0.03 1</specular>
        <pbr><metal><roughness>0.96</roughness><metalness>0.0</metalness></metal></pbr></material></visual></link></model>

    <!-- ═══ SECTOR 1: Storage Yard (-200..200, -200..200) ═══ -->
    <model name="s1_fence_n"><static>true</static><pose>0 200 2 0 0 0</pose><link name="l">
      <collision name="c"><geometry><box><size>402 0.5 4</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>402 0.5 4</size></box></geometry>
