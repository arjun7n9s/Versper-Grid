[Unit]
Description=VesperGrid vLLM (Qwen-VL on MI300X via Docker)
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
ExecStartPre=-/usr/bin/docker rm -f vespergrid-vllm
ExecStart=/usr/bin/docker run --rm   --name vespergrid-vllm   --device=/dev/kfd   --device=/dev/dri   --group-add video   --ipc=host   --shm-size=8g   -p 9001:8000   -e HIP_VISIBLE_DEVICES=0   -e PYTORCH_ALLOC_CONF=expandable_segments:True   vllm/vllm-openai-rocm:v0.17.1   --model Qwen/Qwen2.5-VL-7B-Instruct   --tensor-parallel-size 1   --max-model-len 8192   --gpu-memory-utilization 0.85   --trust-remote-code
ExecStop=/usr/bin/docker stop vespergrid-vllm
Restart=on-failure
RestartSec=15
TimeoutStartSec=600
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
