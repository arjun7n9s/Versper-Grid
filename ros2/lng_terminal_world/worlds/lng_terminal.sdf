        </visual>
        <collision name="col"><geometry><cylinder><radius>0.18</radius><length>22</length></cylinder></geometry></collision>
      </link>
    </model>

    <!-- ── Control building ── -->
    <model name="control_room">
      <static>true</static>
      <pose>18 -12 2 0 0 0</pose>
      <link name="structure">
        <visual name="walls">
          <geometry><box><size>8 6 4</size></box></geometry>
          <material>
            <ambient>0.60 0.57 0.52 1</ambient>
            <diffuse>0.70 0.67 0.60 1</diffuse>
            <specular>0.05 0.05 0.04 1</specular>
            <pbr><metal><roughness>0.88</roughness><metalness>0.0</metalness></metal></pbr>
          </material>
        </visual>
        <visual name="roof">
          <pose>0 0 2.15 0 0 0</pose>
