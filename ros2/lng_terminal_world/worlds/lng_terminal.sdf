    <!-- ── Drone — detailed quadrotor frame ── -->
    <model name="drone">
      <static>true</static>
      <pose>0 0 18 0 0 0.785</pose>
      <link name="base_link">
        <!-- Central body -->
        <visual name="body_vis">
          <geometry><box><size>0.35 0.35 0.10</size></box></geometry>
          <material>
            <ambient>0.08 0.08 0.10 1</ambient>
            <diffuse>0.12 0.12 0.15 1</diffuse>
            <specular>0.4 0.4 0.45 1</specular>
            <pbr><metal><roughness>0.25</roughness><metalness>0.8</metalness></metal></pbr>
          </material>
        </visual>
        <!-- Arms -->
        <visual name="arm_ne">
          <pose>0.18 0.18 0 0 0 0.785</pose>
          <geometry><box><size>0.52 0.045 0.035</size></box></geometry>
          <material><ambient>0.12 0.12 0.14 1</ambient><diffuse>0.16 0.16 0.18 1</diffuse><specular>0.3 0.3 0.3 1</specular></material>
        </visual>
        <visual name="arm_nw">
          <pose>-0.18 0.18 0 0 0 -0.785</pose>
          <geometry><box><size>0.52 0.045 0.035</size></box></geometry>
          <material><ambient>0.12 0.12 0.14 1</ambient><diffuse>0.16 0.16 0.18 1</diffuse><specular>0.3 0.3 0.3 1</specular></material>
        </visual>
        <visual name="arm_sw">
          <pose>-0.18 -0.18 0 0 0 0.785</pose>
          <geometry><box><size>0.52 0.045 0.035</size></box></geometry>
          <material><ambient>0.12 0.12 0.14 1</ambient><diffuse>0.16 0.16 0.18 1</diffuse><specular>0.3 0.3 0.3 1</specular></material>
        </visual>
        <visual name="arm_se">
          <pose>0.18 -0.18 0 0 0 -0.785</pose>
          <geometry><box><size>0.52 0.045 0.035</size></box></geometry>
          <material><ambient>0.12 0.12 0.14 1</ambient><diffuse>0.16 0.16 0.18 1</diffuse><specular>0.3 0.3 0.3 1</specular></material>
        </visual>
        <!-- Motor hubs -->
        <visual name="motor_ne"><pose>0.30 0.30 0.02 0 0 0</pose><geometry><cylinder><radius>0.04</radius><length>0.06</length></cylinder></geometry><material><ambient>0.6 0.6 0.0 1</ambient><diffuse>0.8 0.8 0.0 1</diffuse><specular>0.3 0.3 0.0 1</specular></material></visual>
        <visual name="motor_nw"><pose>-0.30 0.30 0.02 0 0 0</pose><geometry><cylinder><radius>0.04</radius><length>0.06</length></cylinder></geometry><material><ambient>0.6 0.6 0.0 1</ambient><diffuse>0.8 0.8 0.0 1</diffuse><specular>0.3 0.3 0.0 1</specular></material></visual>
        <visual name="motor_sw"><pose>-0.30 -0.30 0.02 0 0 0</pose><geometry><cylinder><radius>0.04</radius><length>0.06</length></cylinder></geometry><material><ambient>0.6 0.6 0.0 1</ambient><diffuse>0.8 0.8 0.0 1</diffuse><specular>0.3 0.3 0.0 1</specular></material></visual>
        <visual name="motor_se"><pose>0.30 -0.30 0.02 0 0 0</pose><geometry><cylinder><radius>0.04</radius><length>0.06</length></cylinder></geometry><material><ambient>0.6 0.6 0.0 1</ambient><diffuse>0.8 0.8 0.0 1</diffuse><specular>0.3 0.3 0.0 1</specular></material></visual>
        <!-- Downward gimbal camera -->
        <visual name="gimbal">
          <pose>0 0 -0.07 0 0 0</pose>
          <geometry><sphere><radius>0.045</radius></sphere></geometry>
          <material>
            <ambient>0.05 0.05 0.05 1</ambient>
            <diffuse>0.07 0.07 0.07 1</diffuse>
            <specular>0.5 0.5 0.5 1</specular>
            <pbr><metal><roughness>0.12</roughness><metalness>0.0</metalness></metal></pbr>
          </material>
        </visual>
        <collision name="body_col"><geometry><box><size>0.35 0.35 0.10</size></box></geometry></collision>
        <!-- Drone downward camera sensor -->
        <sensor name="drone_cam" type="camera">
          <pose>0 0 -0.12 0 1.5707 0</pose>
          <update_rate>5</update_rate>
          <camera>
            <horizontal_fov>1.0472</horizontal_fov>
            <image><width>1280</width><height>720</height><format>R8G8B8</format></image>
            <clip><near>0.5</near><far>200</far></clip>
            <noise><type>gaussian</type><mean>0</mean><stddev>0.002</stddev></noise>
          </camera>
        </sensor>
      </link>
    </model>

  </world>
</sdf>
