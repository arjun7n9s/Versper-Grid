      <diffuse>0.90 0.70 0.35 1</diffuse><specular>0.18 0.12 0.04 1</specular>
      <attenuation><range>220</range><constant>0.3</constant><linear>0.015</linear><quadratic>0.0001</quadratic></attenuation></light>
