<?xml version="1.0" ?>
<!--
  NORTHGATE LNG TERMINAL — VesperGrid Incident Simulation
  INCIDENT: Sector 4 Flange Breach, Tank B-4, 03:42 UTC
  Gas sensor GS-04 exceeded LEL. Drone D-1 dispatched.
  Worker evacuation in progress. Flare stack lit.
-->
<sdf version="1.9">
  <world name="lng_terminal">

    <physics type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="gz-sim-physics-system"          name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-user-commands-system"    name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-sensors-system"          name="gz::sim::systems::Sensors"/>
    <plugin filename="gz-sim-particle-emitter-system" name="gz::sim::systems::ParticleEmitter"/>

    <!-- Night scene: 03:42 UTC — no sky tag (Fortress Ogre2 bug), grid off -->
    <scene>
      <ambient>0.18 0.18 0.22 1.0</ambient>
      <background>0.08 0.10 0.16 1.0</background>
      <shadows>true</shadows>
      <grid>false</grid>
      <origin_visual>false</origin_visual>
      <fog>
        <color>0.15 0.17 0.25 1</color>
        <type>linear</type>
        <start>100</start>
        <end>350</end>
        <density>0.002</density>
      </fog>
    </scene>

    <!-- Moonlight: cold blue-white directional -->
    <light type="directional" name="moonlight">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 100 0 0 0</pose>
      <diffuse>0.25 0.28 0.38 1</diffuse>
      <specular>0.08 0.09 0.14 1</specular>
      <direction>0.3 -0.5 -0.8</direction>
      <attenuation><range>2000</range><constant>0.9</constant><linear>0.0</linear><quadratic>0.0</quadratic></attenuation>
    </light>

    <!-- Facility flood lights: sodium vapour, warm orange, 4 quadrants -->
